// §22-23). Cross-references to prior tables use SCALAR FKs (enforced at DB
// level) so no completed model is modified. AI/Video stay provider-independent
// (Constitution Art. VII) — no vendor concept is stored beyond an opaque ref.
// =====================================================================

enum CourseStatus {
  DRAFT
  PUBLISHED
  RETIRED
}
enum EnrollableType {
  COURSE
  PROGRAM
  PATH
}
enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  WITHDRAWN
}
enum AssignmentStatus {
  OPEN
  SUBMITTED
  GRADED
  CLOSED
}
enum AssessmentKind {
  ASSESSMENT
  QUIZ
}
enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  TEXT
}
enum LiveSessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  NO_SHOW
  CANCELLED
}
enum CertificateStatus {
  ISSUED
  REVOKED
}
enum AICapability {
  ASSISTANT
  RECOMMENDATION
}

// ---------- Curriculum ----------
model Course {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title          String
  description    String?      @db.Text
  subject        String
  ownerAccountId String       @map("owner_account_id") @db.Uuid
  status         CourseStatus @default(DRAFT)
  jurisdictionId String?      @map("jurisdiction_id") @db.Uuid

  modules CourseModule[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid
  isDeleted Boolean  @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?  @map("deleted_by") @db.Uuid
  recordVersion Int  @default(1) @map("record_version")

  @@index([ownerAccountId])
  @@index([subject])
  @@index([status])
  @@map("course")
}

model CourseModule {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId      String  @map("course_id") @db.Uuid
  title         String

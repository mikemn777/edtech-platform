  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([bookingId, changedAt])
  @@map("booking_status_history")
}

// =====================================================================
// PHASE 3 — LEARNING DELIVERY, COMMUNICATION, INTELLIGENCE
// Courses/Programs/Paths, Resources/Notes, Assignments, Assessments/Quizzes,

model Booking {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId         String        @map("student_id") @db.Uuid // -> student_profile(id)
  tutorId           String        @map("tutor_id") @db.Uuid // -> tutor_profile(id)
  offeringId        String?       @map("offering_id") @db.Uuid // -> tutor_offering(id)
  availabilityId    String?       @map("availability_id") @db.Uuid // -> tutor_availability(id)
  bookedByAccountId String        @map("booked_by_account_id") @db.Uuid // -> user_account(id)
  scheduledStart    DateTime      @map("scheduled_start") @db.Timestamptz(6)
  scheduledEnd      DateTime      @map("scheduled_end") @db.Timestamptz(6)
  status            BookingStatus @default(REQUESTED)
  // Indicative price captured at request; commercial RULES (final price,
  // commission, payment) are Pending Business Decisions (BR-100/101).
  price             Decimal?      @db.Decimal(18, 4)
  currencyId        String?       @map("currency_id") @db.Uuid
  jurisdictionId    String?       @map("jurisdiction_id") @db.Uuid
  classification    String        @default("minor_related")

  statusHistory BookingStatusHistory[]

  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy     String?   @map("created_by") @db.Uuid
  updatedBy     String?   @map("updated_by") @db.Uuid
  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy     String?   @map("deleted_by") @db.Uuid
  recordVersion Int       @default(1) @map("record_version")

  @@index([studentId])
  @@index([tutorId])
  @@index([status])
  @@index([tutorId, status])
  @@index([scheduledStart])
  @@map("booking")
}

model BookingStatusHistory {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId  String        @map("booking_id") @db.Uuid
  fromStatus BookingStatus? @map("from_status")
  toStatus   BookingStatus @map("to_status")
  changedAt  DateTime      @default(now()) @map("changed_at") @db.Timestamptz(6)
  changedBy  String?       @map("changed_by") @db.Uuid

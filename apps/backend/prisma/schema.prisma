  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid
  isDeleted Boolean  @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?  @map("deleted_by") @db.Uuid
  recordVersion Int  @default(1) @map("record_version")

  @@index([authorAccountId])
  @@index([contextType, contextId])
  @@map("note")
}

// ---------- Assignments / Homework ----------
model Assignment {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?          @db.Text
  courseId    String?          @map("course_id") @db.Uuid
  assignedByAccountId String   @map("assigned_by_account_id") @db.Uuid
  studentId   String           @map("student_id") @db.Uuid // -> student_profile(id)
  dueAt       DateTime?        @map("due_at") @db.Timestamptz(6)
  status      AssignmentStatus @default(OPEN)
  classification String        @default("minor_related")

  submissions AssignmentSubmission[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid
  isDeleted Boolean  @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?  @map("deleted_by") @db.Uuid
  recordVersion Int  @default(1) @map("record_version")

  @@index([studentId])
  @@index([courseId])
  @@index([status])
  @@map("assignment")
}

model AssignmentSubmission {
  id               String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assignmentId     String  @map("assignment_id") @db.Uuid
  studentId        String  @map("student_id") @db.Uuid
  submittedAt      DateTime? @map("submitted_at") @db.Timestamptz(6)
  contentReference String? @map("content_reference")
  status           String  @default("draft")
  feedback         String? @db.Text
  score            Decimal? @db.Decimal(18, 4)
  classification   String  @default("minor_related")

  assignment Assignment @relation(fields: [assignmentId], references: [id])

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid
  isDeleted Boolean  @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?  @map("deleted_by") @db.Uuid
  recordVersion Int  @default(1) @map("record_version")

  @@index([assignmentId])
  @@index([studentId])
  @@map("assignment_submission")
}

// ---------- Assessments / Quizzes ----------
model Assessment {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title          String
  ownerAccountId String         @map("owner_account_id") @db.Uuid
  kind           AssessmentKind @default(ASSESSMENT)
  status         CourseStatus   @default(DRAFT)
  courseId       String?        @map("course_id") @db.Uuid

  questions   AssessmentQuestion[]
  submissions AssessmentSubmission[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid
  isDeleted Boolean  @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?  @map("deleted_by") @db.Uuid
  recordVersion Int  @default(1) @map("record_version")

  @@index([ownerAccountId])
  @@index([kind])
  @@index([status])
  @@map("assessment")
}

model AssessmentQuestion {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessmentId  String       @map("assessment_id") @db.Uuid
  prompt        String       @db.Text
  questionType  QuestionType @map("question_type")
  options       Json?
  // Answer key — evaluated server-side, never exposed to students (privacy).
  answerKey     Json?        @map("answer_key")
  points        Int          @default(1)
  sequenceOrder Int          @map("sequence_order")

  assessment Assessment @relation(fields: [assessmentId], references: [id])

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid
  isDeleted Boolean  @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?  @map("deleted_by") @db.Uuid
  recordVersion Int  @default(1) @map("record_version")

  @@unique([assessmentId, sequenceOrder])
  @@index([assessmentId])
  @@map("assessment_question")
}

model AssessmentSubmission {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessmentId  String    @map("assessment_id") @db.Uuid
  studentId     String    @map("student_id") @db.Uuid // -> student_profile(id)
  submittedAt   DateTime? @map("submitted_at") @db.Timestamptz(6)
  status        String    @default("in_progress")
  score         Decimal?  @db.Decimal(18, 4)
  maxScore      Decimal?  @map("max_score") @db.Decimal(18, 4)
  classification String   @default("minor_related")

  assessment Assessment          @relation(fields: [assessmentId], references: [id])
  answers    AssessmentAnswer[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid
  isDeleted Boolean  @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?  @map("deleted_by") @db.Uuid
  recordVersion Int  @default(1) @map("record_version")

  @@index([assessmentId])
  @@index([studentId])
  @@map("assessment_submission")
}

model AssessmentAnswer {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  submissionId String  @map("submission_id") @db.Uuid
  questionId   String  @map("question_id") @db.Uuid
  answer       Json?
  isCorrect    Boolean? @map("is_correct")
  awardedPoints Int?    @map("awarded_points")

  submission AssessmentSubmission @relation(fields: [submissionId], references: [id])

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid
  isDeleted Boolean  @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?  @map("deleted_by") @db.Uuid
  recordVersion Int  @default(1) @map("record_version")

  @@unique([submissionId, questionId])
  @@index([submissionId])
  @@map("assessment_answer")
}

// ---------- Live Sessions ----------
model LiveSession {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId      String?           @map("booking_id") @db.Uuid // -> booking(id)
  tutorId        String            @map("tutor_id") @db.Uuid
  studentId      String            @map("student_id") @db.Uuid
  scheduledStart DateTime          @map("scheduled_start") @db.Timestamptz(6)
  scheduledEnd   DateTime          @map("scheduled_end") @db.Timestamptz(6)
  actualStart    DateTime?         @map("actual_start") @db.Timestamptz(6)
  actualEnd      DateTime?         @map("actual_end") @db.Timestamptz(6)
  status         LiveSessionStatus @default(SCHEDULED)
  // Opaque media-provider reference. The provider is a PTD behind a port; no
  // vendor concept leaks into the domain (Constitution Art. VII).
  mediaReference String?           @map("media_reference")
  classification String            @default("minor_related")

  attendance SessionAttendance[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid
  isDeleted Boolean  @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?  @map("deleted_by") @db.Uuid
  recordVersion Int  @default(1) @map("record_version")

  @@index([tutorId])
  @@index([studentId])
  @@index([status, scheduledStart])
  @@map("live_session")
}

model SessionAttendance {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId           String    @map("session_id") @db.Uuid
  participantAccountId String   @map("participant_account_id") @db.Uuid
  joinedAt            DateTime? @map("joined_at") @db.Timestamptz(6)
  leftAt              DateTime? @map("left_at") @db.Timestamptz(6)
  attendanceStatus    String    @default("absent") @map("attendance_status")

  session LiveSession @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid
  isDeleted Boolean  @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?  @map("deleted_by") @db.Uuid
  recordVersion Int  @default(1) @map("record_version")

  @@unique([sessionId, participantAccountId])
  @@index([sessionId])
  @@map("session_attendance")
}

// ---------- Certificates ----------
model Certificate {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId     String            @map("student_id") @db.Uuid // -> student_profile(id)
  title         String
  issuedForType String            @map("issued_for_type") // course|program|path
  issuedForId   String?           @map("issued_for_id") @db.Uuid
  serialNumber  String            @unique @map("serial_number")
  issuedAt      DateTime          @default(now()) @map("issued_at") @db.Timestamptz(6)
  status        CertificateStatus @default(ISSUED)
  classification String           @default("minor_related")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid
  isDeleted Boolean  @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?  @map("deleted_by") @db.Uuid
  recordVersion Int  @default(1) @map("record_version")

  @@index([studentId])
  @@index([issuedForType, issuedForId])
  @@map("certificate")
}

// ---------- AI (provider-independent — Art. VII) ----------
model AIInteraction {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestorAccountId String     @map("requestor_account_id") @db.Uuid
  capability        AICapability
  providerKey       String?     @map("provider_key") // opaque; adapter-resolved
  contextReference  String?     @map("context_reference")
  status            String      @default("completed")
  occurredAt        DateTime    @default(now()) @map("occurred_at") @db.Timestamptz(6)
  classification    String      @default("personal")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid
  isDeleted Boolean  @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?  @map("deleted_by") @db.Uuid
  recordVersion Int  @default(1) @map("record_version")

  @@index([requestorAccountId])
  @@index([capability, occurredAt])
  @@map("ai_interaction")
}

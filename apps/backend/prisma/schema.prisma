// ---------- Resources / Files / Notes ----------
model Resource {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerAccountId String  @map("owner_account_id") @db.Uuid
  title          String
  description    String? @db.Text
  // Opaque storage reference (via FileStorage port). Access-controlled; sensitive
  // resources encrypted at rest (DB Arch §13, §21).
  storageReference String @map("storage_reference")
  contentType    String  @map("content_type")
  courseId       String? @map("course_id") @db.Uuid
  classification String  @default("operational")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy String?  @map("created_by") @db.Uuid
  updatedBy String?  @map("updated_by") @db.Uuid
  isDeleted Boolean  @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  deletedBy String?  @map("deleted_by") @db.Uuid
  recordVersion Int  @default(1) @map("record_version")

  @@index([ownerAccountId])
  @@index([courseId])
  @@map("resource")
}

model Note {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  authorAccountId String  @map("author_account_id") @db.Uuid

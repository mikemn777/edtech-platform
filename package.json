{
  "name": "edu-ecosystem-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Education Ecosystem Platform — production-grade, multi-country, multi-language monorepo. Governed by the Project Constitution v1.0.",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "db:generate": "pnpm --filter @edu/backend db:generate",
    "db:migrate": "pnpm --filter @edu/backend db:migrate",
    "db:migrate:deploy": "pnpm --filter @edu/backend db:migrate:deploy",
    "db:seed": "pnpm --filter @edu/backend db:seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}

# =====================================================================
# Education Ecosystem Platform — Environment Configuration (Blueprint §10)
# Copy to .env.local (dev) / provided by secrets manager (staging, prod).
# NEVER commit real secrets (Blueprint §11). All config validated at startup.
# =====================================================================

# ---- Runtime ----
NODE_ENV=development
APP_NAME=edu-ecosystem-platform

# ---- Backend ----
BACKEND_PORT=4000
BACKEND_GLOBAL_PREFIX=api
API_DEFAULT_VERSION=1
# Comma-separated allowed CORS origins (no wildcard in production)
CORS_ORIGINS=http://localhost:3000

# ---- PostgreSQL (module 4) ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=edu_app
POSTGRES_PASSWORD=change_me_in_local_only
POSTGRES_DB=edu_platform
# Prisma connection string (module 5) — derived; keep in sync with the above
DATABASE_URL=postgresql://edu_app:change_me_in_local_only@localhost:5432/edu_platform?schema=public

# ---- Redis (module 6) ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# ---- Authentication (module 10) ----
# Secrets: injected at runtime from secrets manager in staging/prod (Blueprint §11)
JWT_ACCESS_SECRET=dev_only_access_secret_change_me
JWT_REFRESH_SECRET=dev_only_refresh_secret_change_me
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600
PASSWORD_HASH_MEMORY_COST=19456
PASSWORD_HASH_TIME_COST=2
PASSWORD_HASH_PARALLELISM=1

# ---- Localization (module 14) ----
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,ar,tr
DEFAULT_LOCALE=en-US

# ---- File Storage abstraction (module 18) ----
# STORAGE_DRIVER: local | s3 (concrete provider is a Pending Technical Decision)
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=./.storage

# ---- Logging (module 20) ----
LOG_LEVEL=debug
LOG_PRETTY=true

# ---- Health / ops ----
HEALTH_DB_TIMEOUT_MS=2000
